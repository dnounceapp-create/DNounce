{
  "crons": [
    {
      "path": "/api/internal/record-lifecycle",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cleanup-ghost-users",
      "schedule": "0 0 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "dnounce.com"
        }
      ],
      "destination": "https://www.dnounce.com/:path*",
      "permanent": true
    }
  ]
}
